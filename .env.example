# AI Productivity Suite - Environment Variables
# Copy this file to '.env.local' and add your actual API keys.

# ==========================================
# 1. Google Gemini API (Required for Backend)
# ==========================================
# Get your key here: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ==========================================
# 2. Clerk Authentication (Required for Frontend)
# ==========================================
# Get your keys from the Clerk Dashboard: https://dashboard.clerk.com
# Note: Authentication is currently bypassed, but these are needed when re-enabled.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here

# ==========================================
# 3. Backend Configuration (Optional)
# ==========================================
# Default port the FastAPI backend runs on
PORT=8000
# Database path for SQLite
DATABASE_URL=sqlite:///./chat_history.db
